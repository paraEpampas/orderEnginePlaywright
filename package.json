{
  "name": "order-engine-playwright",
  "version": "1.0.0",
  "description": "Playwright test automation framework for Order Engine",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "HEADLESS=false npx playwright test --headed",
    "test:health-check": "SUITE=health-check COUNTRY=ALL npx playwright test",
    "test:health-check:uk": "SUITE=health-check COUNTRY=UK npx playwright test",
    "test:health-check:us": "SUITE=health-check COUNTRY=US npx playwright test",
    "test:health-check:de": "SUITE=health-check COUNTRY=DE npx playwright test",
    "test:health-check:be": "SUITE=health-check COUNTRY=BE npx playwright test",
    "test:health-check:nl": "SUITE=health-check COUNTRY=NL npx playwright test",
    "test:health-check:fr": "SUITE=health-check COUNTRY=FR npx playwright test",
    "test:regression": "SUITE=regression COUNTRY=ALL npx playwright test",
    "test:regression:uk": "SUITE=regression COUNTRY=UK npx playwright test",
    "test:regression:us": "SUITE=regression COUNTRY=US npx playwright test",
    "test:regression:de": "SUITE=regression COUNTRY=DE npx playwright test",
    "test:regression:be": "SUITE=regression COUNTRY=BE npx playwright test",
    "test:regression:nl": "SUITE=regression COUNTRY=NL npx playwright test",
    "test:regression:fr": "SUITE=regression COUNTRY=FR npx playwright test",
    "test:uk": "COUNTRY=UK npx playwright test",
    "test:us": "COUNTRY=US npx playwright test",
    "test:de": "COUNTRY=DE npx playwright test",
    "test:be": "COUNTRY=BE npx playwright test",
    "test:nl": "COUNTRY=NL npx playwright test",
    "test:fr": "COUNTRY=FR npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:functional": "npx playwright test --grep @functional",
    "test:uat": "ENV=uat npx playwright test",
    "report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.7"
  }
}
